{
  "name": "hulubul-front",
  "version": "0.1.0",
  "private": true,
  "description": "hulubul.com landing page — Next.js frontend for the Strapi 5 backend",
  "scripts": {
    "predev": "node -e \"require('fs').existsSync('.env.local') || (require('fs').existsSync('.env.cloud') && require('fs').copyFileSync('.env.cloud', '.env.local'))\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^15.1.6",
    "qs": "^6.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.5",
    "@types/qs": "^6.9.17",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.6",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
