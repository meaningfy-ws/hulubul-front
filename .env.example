# .env.example — copy to .env.local for development. All variables are
# optional unless marked REQUIRED. Defaults make local dev work with
# zero configuration; production should set the values explicitly.
# Never commit a real .env.local — it's gitignored.

# ──────────────────────────────────────────────────────────────────
# Strapi backend (REQUIRED in any environment that talks to Strapi)
# ──────────────────────────────────────────────────────────────────

NEXT_PUBLIC_STRAPI_URL=https://api.hulubul.com
STRAPI_API_TOKEN=

# Set to "0" only when the Strapi instance has a self-signed cert.
# Disables TLS verification for the whole Node process — remove once
# the backend has a valid certificate.
NODE_TLS_REJECT_UNAUTHORIZED=

# ──────────────────────────────────────────────────────────────────
# Site identity & SEO
# ──────────────────────────────────────────────────────────────────

# Used by lib/seo.ts → metadataBase, canonical URLs, sitemap, OG image
# absolute URLs. Falls back to https://hulubul.com when unset.
NEXT_PUBLIC_SITE_URL=https://hulubul.com

# Google Search Console / Bing Webmaster verification meta tags.
# Tag is only emitted when the env var is non-empty. Get the values
# from search.google.com/search-console and bing.com/webmasters.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# ──────────────────────────────────────────────────────────────────
# Analytics — GA4 via gtag.js (browser-side)
# ──────────────────────────────────────────────────────────────────

# Production: G-3M58NGR6PX. Local dev: leave empty so no tracker
# loads. Preview / staging deploys should use a SEPARATE GA4 property
# so previews don't pollute prod analytics.
# When unset, <Analytics> renders nothing — no gtag/js request fires.
NEXT_PUBLIC_GA_ID=G-3M58NGR6PX

# ──────────────────────────────────────────────────────────────────
# Server-side conversions — GA4 Measurement Protocol
# ──────────────────────────────────────────────────────────────────

# Same measurement ID as above, used server-side from
# app/api/{waitlist,survey}/route.ts.
GA4_MEASUREMENT_ID=G-3M58NGR6PX

# Provision in GA4 admin → Data Streams → choose your stream →
# Measurement Protocol API secrets → Create. KEEP SECRET — never
# expose with NEXT_PUBLIC_ prefix.
# When unset, server-side dispatch is silently skipped; browser-side
# GA4 still works on its own.
GA4_API_SECRET=

# ──────────────────────────────────────────────────────────────────
# Future / deferred — leave unset until we adopt them
# ──────────────────────────────────────────────────────────────────

# Google Tag Manager — only if/when we migrate from gtag to GTM
# (tracking spec §3.1.1). Adding a second pixel is the natural moment.
NEXT_PUBLIC_GTM_ID=

# Meta Conversions API — when we run paid Meta campaigns.
# Get from business.facebook.com → Events Manager.
META_CAPI_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# TikTok Events API — when we run paid TikTok campaigns.
# Get from business.tiktok.com → Events Manager.
TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_TOKEN=

